{
  "name": "practica-ciber-pps",
  "version": "1.0.0",
  "description": "Sistema de registro de IMC",
  "main": "src/server.js",
"scripts": {
  "start": "node src/server.js",
  "dev": "nodemon src/server.js",
  "test": "jest --testPathIgnorePatterns=api.tests.js,records.whitebox.tests.js",
  "test:coverage": "jest --coverage --testPathIgnorePatterns=api.tests.js,records.whitebox.tests.js",
  "test:watch": "jest --watch",
  "coverage:open": "npm run test:coverage && start coverage/index.html",
  "semgrep:check": "semgrep --config .semgrep.yml --json src/",
  "semgrep:fix": "semgrep --config .semgrep.yml --json --output semgrep-report.json src/",
  "semgrep:report": "npm run semgrep:fix && echo '✅ Reporte generado en semgrep-report.json'",
  "security:check": "npm run semgrep:check && npm run gitleaks:check",
  "gitleaks:check": "gitleaks detect --verbose --redact"
},
  "repository": {
    "type": "git",
    "url": "git+https://github.com/camachoo18/PRACTICA-CIBER-PPS.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/camachoo18/PRACTICA-CIBER-PPS/issues"
  },
  "homepage": "https://github.com/camachoo18/PRACTICA-CIBER-PPS#readme",
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.3",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "chromedriver": "^143.0.4",
    "cypress": "^15.8.2",
    "jest": "^30.2.0",
    "mocha": "^11.7.5",
    "sqlite3": "^5.0.2",
    "supertest": "^7.2.2"
  }
}
